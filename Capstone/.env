# =============================================================================
# FIAA — Fraud Intelligence AI Assistant · environment configuration
# -----------------------------------------------------------------------------
# 1.  Copy this file:           cp .env.example .env
# 2.  Paste your keys below.    (Keys are read ONLY from here — never the UI.)
# 3.  Leave keys blank to run in DEMO MODE — the full pipeline still works
#     offline with realistic synthetic output. Add a Groq key for live LLMs.
# =============================================================================

# ---- External API keys ------------------------------------------------------
# Groq (https://console.groq.com)  — powers all LLM agents. Blank => DEMO MODE.
GROQ_API_KEY=""

# Tavily (https://tavily.com)      — live web search for the Search agent.
# Blank => Search agent uses an offline knowledge stub.
TAVILY_API_KEY=""

# LangSmith (https://smith.langchain.com) — chain tracing. Optional.
LANGCHAIN_API_KEY=""

# ---- LangSmith tracing (only used if LANGCHAIN_API_KEY is set) ---------------
LANGCHAIN_TRACING_V2=True
LANGCHAIN_PROJECT=fiaa-fraud
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ---- Webhook / API security -------------------------------------------------
# Shared secret the bank rule-engine sends as the  X-API-Key  header.
FIAA_API_KEY=fiaa-secret-key-2025
API_PORT=8001
METRICS_PORT=8000
STREAMLIT_PORT=8501

# ---- Model chain (fallback on 429:  70b -> 8b -> gemma2) ---------------------
MODEL_SUPERVISOR=llama-3.3-70b-versatile
MODEL_REPORT=llama-3.3-70b-versatile
MODEL_EVALUATOR=llama-3.3-70b-versatile
MODEL_SMALL=llama-3.1-8b-instant
MODEL_FALLBACK=gemma2-9b-it

# ---- RAG / embeddings -------------------------------------------------------
EMBED_MODEL=all-MiniLM-L6-v2
CHROMA_COLLECTION=fiaa_knowledge
RAG_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ---- Pipeline behaviour -----------------------------------------------------
ITERATION_CAP=5
HIGH_RISK_THRESHOLD=7.0
MAX_ALERT_CHARS=5000
ENV=dev
